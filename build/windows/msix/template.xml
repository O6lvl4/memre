<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="memre"
        Arguments=""
        InstallLocation="C:\Program Files\Aid-On\Memre">
    </Installer>
    <PackageInformation
        PackageName="Memre"
        PackageDisplayName="Memre"
        PublisherName="CN=Aid-On"
        PublisherDisplayName="Aid-On"
        Version="0.1.0.0"
        PackageDescription="Local-first memory browser for Claude Code">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="org.aid-on.memre"
                Description="Local-first memory browser for Claude Code"
                DisplayName="Memre"
                ExecutableName="memre"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Memre</DisplayName>
            <PublisherDisplayName>Aid-On</PublisherDisplayName>
            <Description>Local-first memory browser for Claude Code</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="memre.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
